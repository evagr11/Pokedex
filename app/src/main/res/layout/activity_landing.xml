<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@mipmap/fondoandroid"
    android:foregroundTint="#509276"
    tools:context=".View.LandingActivity">

    <Button
        android:id="@+id/btnAcceder"
        android:layout_width="273dp"
        android:layout_height="65dp"
        android:backgroundTint="#b9e0cf"
        android:drawableLeft="@mipmap/iconopokedex4"
        android:text="@string/accede_a_tu_pokedex"
        android:textColor="#337157"
        android:visibility="invisible"
        app:cornerRadius="30dp"
        app:iconSize="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.634" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:indeterminateTint="#2B2D30"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnAcceder" />
</androidx.constraintlayout.widget.ConstraintLayout>